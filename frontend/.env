# ─────────────────────────────────────────────────
# Dashboard EMP - Frontend Environment Variables
# ─────────────────────────────────────────────────

# URL API backend (Express server)
VITE_API_URL=http://localhost:5000/api

# Mode Data Dummy:
# Set ke "true" untuk memaksa frontend menggunakan data dummy lokal
# tanpa perlu koneksi ke backend/database.
# Jika "false" (default), frontend akan coba hit backend,
# dan otomatis fallback ke dummy jika backend tidak tersedia.
VITE_USE_DUMMY_DATA=true
